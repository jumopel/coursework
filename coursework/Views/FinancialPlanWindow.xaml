<Window x:Class="coursework.Views.FinancialPlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фінансове планування (Точка беззбитковості)" Height="500" Width="900"
        WindowStartupLocation="CenterOwner" Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15" HorizontalAlignment="Center">
            <TextBlock Text="Точка беззбитковості закладів" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
            <TextBlock Text="Прогрес покриття фіксованих витрат (Оренда + Зарплати) та Unit-прогноз" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="5" Opacity="0.1"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding ShopsData}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White" RowHeight="45" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EAECEE">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#F8F9F9"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="Foreground" Value="#2C3E50"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Заклад" Binding="{Binding ShopName}" Width="1.5*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Фікс. Витрати" Binding="{Binding FixedCosts, StringFormat={}{0:C0}}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="Foreground" Value="#E74C3C"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Поточна Каса" Binding="{Binding CurrentRevenue, StringFormat={}{0:C0}}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="Foreground" Value="#27AE60"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Прогноз окупності" Binding="{Binding EstimatedPayoff}" Width="1.5*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2980B9"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Статус" Binding="{Binding BreakEvenStatus}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Прогрес окупності" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="10,12">
                                    <ProgressBar Value="{Binding BreakEvenProgress}" Maximum="100" Height="20" Foreground="{Binding ProgressColor}" Background="#EAECEE" BorderThickness="0"/>
                                    <TextBlock Text="{Binding BreakEvenProgress, StringFormat={}{0:F1}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>