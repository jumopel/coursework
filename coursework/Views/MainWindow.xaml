<Window x:Class="coursework.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:coursework.ViewModels"
        mc:Ignorable="d"
        Title="GastroMetric - Симуляція Фестивалю" Height="720" Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="▶ Старт" Command="{Binding StartCommand}" 
                            Width="90" Height="35" Margin="0,0,10,0" 
                            Background="#4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

                    <Button Content="⏸ Пауза" Command="{Binding PauseCommand}" 
                            Width="90" Height="35" 
                            Background="#F44336" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Ігровий час:" FontSize="16" Foreground="#555" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ElapsedTimeText}" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Швидкість:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#555"/>
                    <Button Content="1x" Command="{Binding SetSpeed1XCommand}" Width="40" Height="30" Margin="0,0,5,0" Background="#E0E0E0" BorderThickness="0"/>
                    <Button Content="2x" Command="{Binding SetSpeed2XCommand}" Width="40" Height="30" Margin="0,0,5,0" Background="#E0E0E0" BorderThickness="0"/>
                    <Button Content="4x" Command="{Binding SetSpeed4XCommand}" Width="40" Height="30" Background="#E0E0E0" BorderThickness="0"/>
                    <Button Content="➕ Додати зону" Command="{Binding OpenAddZoneCommand}"  Width="120" Height="35" Margin="15,0,0,0" Background="#8E44AD" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="4" ShadowDepth="1"/>
                        </Button.Effect>
                    </Button>

                    <Button Content="🗺 Карта фестивалю" Command="{Binding OpenMapCommand}" 
                            Width="140" Height="35" Margin="15,0,0,0" 
                            Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Button_Click"/>

                    <Button Content="➕ Додати заклад" Command="{Binding OpenAddShopCommand}" 
                            Width="140" Height="35" Margin="10,0,0,0" 
                            Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="4" ShadowDepth="1"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Zones}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" RowDetailsVisibilityMode="VisibleWhenSelected"
                  Background="White" BorderBrush="#E0E0E0" BorderThickness="1" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва Зони" Binding="{Binding ZoneName}" Width="2*"/>
                <DataGridTextColumn Header="Тематика" Binding="{Binding Theme}" Width="2*"/>
                <DataGridTextColumn Header="Людей" Binding="{Binding CurrentVisitors}" Width="Auto"/>
                <DataGridTextColumn Header="Завантаженість (%)" Binding="{Binding OccupancyRate}" Width="Auto"/>
                <DataGridTextColumn Header="Прибуток зони (грн)" Binding="{Binding TotalRevenue}" Width="Auto"/>
                <DataGridTextColumn Header="Завантаженість (%)" Binding="{Binding OccupancyRate}" Width="Auto"/>
                <DataGridTextColumn Header="Прибуток зони (грн)" Binding="{Binding TotalRevenue}" Width="Auto"/>

                <DataGridTemplateColumn Header="Керування" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑 Видалити" 
                        Command="{Binding DataContext.DeleteZoneCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CommandParameter="{Binding}" 
                        Padding="15,2" Margin="5,0" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#FAFAFA" Padding="25,10,10,15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Заклади в цій зоні:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>

                            <DataGrid ItemsSource="{Binding ShopsData}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="True" 
                                      Background="White" BorderThickness="1" BorderBrush="#D0D3D4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Назва Закладу" Binding="{Binding ShopName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Черга (людей)" Binding="{Binding CurrentQueue}" Width="Auto"/>
                                    <DataGridTextColumn Header="Завантаженість (хв)" Binding="{Binding CongestionLevel}" Width="Auto"/>
                                    <DataGridTextColumn Header="Привабливість" Binding="{Binding Attractiveness}" Width="Auto"/>
                                    <DataGridTextColumn Header="Каса (грн)" Binding="{Binding CurrentRevenue}" Width="Auto"/>

                                    <DataGridTextColumn Header="Касири" Binding="{Binding CashiersCount}" Width="Auto"/>
                                    <DataGridTextColumn Header="Кухарі" Binding="{Binding CooksCount}" Width="Auto"/>
                                    <DataGridTemplateColumn Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="📋 Меню" 
                    Command="{Binding DataContext.OpenMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                    CommandParameter="{Binding}"
                    Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    Margin="2" Padding="5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Керування персоналом" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                                    <Button Content="+ Касир (500₴)" 
                                                            Command="{Binding DataContext.HireCashierCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" 
                                                            Margin="0,0,5,0" Padding="8,2" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                                                    <Button Content="+ Кухар (700₴)" 
                                                            Command="{Binding DataContext.HireCookCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                            CommandParameter="{Binding}" 
                                                            Padding="8,2" Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

    </Grid>
</Window>