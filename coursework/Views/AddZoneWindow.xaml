<Window x:Class="coursework.Views.AddZoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати нову зону" Height="380" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Назва зони:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox Text="{Binding ZoneName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,15"/>

            <TextBlock Text="Тематика:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Cuisines}" SelectedItem="{Binding SelectedCuisine}" Padding="6" Margin="0,0,0,15"/>
            <TextBlock Text="Розмір зони (Ширина x Висота):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <UniformGrid Columns="2" Margin="0,0,0,15">
                <TextBox Text="{Binding ZoneWidth, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,5,0"/>
                <TextBox Text="{Binding ZoneHeight, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="5,0,0,0"/>
            </UniformGrid>

            <TextBlock Text="Місткість (макс. кількість людей):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Capacity, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,15"/>

            <TextBlock Text="Тип зони:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding ZoneTypes}" SelectedItem="{Binding SelectedTypeStr}" Padding="6" Margin="0,0,0,15"/>
        </StackPanel>

        <Button Grid.Row="1" Content="➕ Створити зону" Command="{Binding SaveCommand}"
                Height="42" Background="#8E44AD" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
    </Grid>
</Window>