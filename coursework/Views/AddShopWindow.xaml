<Window x:Class="coursework.Views.AddShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати новий заклад" Height="500" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel >
                <TextBlock Text="Назва закладу:" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBox Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,5"/>

                <TextBlock Text="Тип закладу:" FontWeight="Bold" Foreground="#2C3E50"/>
                <ComboBox ItemsSource="{Binding ShopTypes}" SelectedItem="{Binding SelectedType}" Padding="6" Margin="0,0,0,5"/>

                <TextBlock Text="Виберіть зону розміщення:" FontWeight="Bold" Foreground="#2C3E50"/>
                <ComboBox ItemsSource="{Binding AvailableZones}" SelectedItem="{Binding SelectedZone}" DisplayMemberPath="Name" Padding="6" Margin="0,0,0,10"/>

                <UniformGrid Columns="2" Margin="0,0,0,5">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Касири (чол):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding CashiersCount}" Padding="6"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Кухарі (чол):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding CooksCount}" Padding="6"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,5">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Оренда (грн/день):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding DailyRent}" Padding="6"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Зарплати (грн/день):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding StaffsDailySalary}" Padding="6"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,5">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Прийом замовлення (хв):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding OrderTakingMinutes}" Padding="6"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Приготування їжі (хв):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding PrepMinutes}" Padding="6"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,5">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Координата X (карта):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding X}" Padding="6"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Координата Y (карта):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding Y}" Padding="6"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1" Content="➕ Додати заклад у симуляцію" Command="{Binding SaveCommand}"
                Height="42" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,15,0,0"/>
    </Grid>
</Window>