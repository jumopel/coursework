<Window x:Class="coursework.Views.AddShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати новий заклад" Height="310" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F6F9">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Назва закладу:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,15"/>

            <UniformGrid Columns="2" Margin="0,0,0,15">
                <StackPanel Margin="0,0,5,0">
                    <TextBlock Text="Касири (чол):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Cashiers, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock Text="Кухарі (чол):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Cooks, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
            </UniformGrid>

            <UniformGrid Columns="2" Margin="0,0,0,15">
                <StackPanel Margin="0,0,5,0">
                    <TextBlock Text="Оренда (грн/день):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Rent, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock Text="Зарплати (грн/день):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Salary, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <Button Grid.Row="1" Content="🗺 Розмістити на карті" Command="{Binding SaveCommand}"
            Height="42" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
    </Grid>
</Window>