<Window x:Class="coursework.Views.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карта фестивалю — Теплова карта відвідувачів"
        Height="660" Width="860"
        ResizeMode="CanMinimize"
        Background="#1a1a2e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Heatmap bitmap -->
        <Border Grid.Row="0"
                Margin="10"
                BorderBrush="#444"
                BorderThickness="1"
                CornerRadius="4"
                ClipToBounds="True">
            <Image Source="{Binding HeatmapImage}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">

            <TextBlock Text="Мало"
                       Foreground="#aaa"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <Border Width="200" Height="16" CornerRadius="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#220000FF" Offset="0"/>
                        <GradientStop Color="#8000C8FF" Offset="0.35"/>
                        <GradientStop Color="#C0FFFF00" Offset="0.65"/>
                        <GradientStop Color="#FFFF0000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <TextBlock Text="Багато"
                       Foreground="#aaa"
                       VerticalAlignment="Center"
                       Margin="6,0,20,0"/>

            <Ellipse Width="14" Height="14"
                     Fill="White"
                     Stroke="#222"
                     StrokeThickness="2"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
            <TextBlock Text="Магазин"
                       Foreground="#aaa"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
