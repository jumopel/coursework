<Window x:Class="coursework.Views.EditMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Керування меню закладу" Height="580" Width="880"
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Назва страви:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ціна (грн):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Собівартість (грн):" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewCostPrice, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6" BorderBrush="#E67E22" BorderThickness="1.5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Час (хв):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewPrepTime, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                    </StackPanel>
                </Grid>

                <Border Background="#FFF8F0" BorderBrush="#F0C080" BorderThickness="1"
                        CornerRadius="4" Padding="8,5" Margin="0,0,0,8">
                    <TextBlock Text="{Binding MarginHint}" Foreground="#D35400" FontSize="12" FontWeight="Bold"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Категорія:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дієта:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding DietaryTags}" SelectedItem="{Binding SelectedDietaryTag}" Padding="6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Скасувати" Command="{Binding CancelEditCommand}"
                                Height="32" Margin="0,0,8,0" Padding="12,0"
                                Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding SubmitButtonText}" Command="{Binding SubmitProductCommand}"
                                Height="32" Width="110"
                                Background="{Binding SubmitButtonColor}" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding MenuItems}" AutoGenerateColumns="False"
                  CanUserAddRows="False" Background="White" HeadersVisibility="Column"
                  RowHeight="38" AlternatingRowBackground="#F2F4F4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва страви" Binding="{Binding Name}" Width="*"/>

                <DataGridTextColumn Header="Ціна (грн)" Binding="{Binding Price}" Width="85"/>

                <DataGridTextColumn Header="Собівартість (грн)" Binding="{Binding CostPrice}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#E67E22"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Маржа" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding MarginPercent}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="Bold" Foreground="#27AE60"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Час (хв)" Binding="{Binding PreparationTime.TotalMinutes}" Width="70"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Дієта" Binding="{Binding DietaryTag}" Width="80"/>

                <DataGridTemplateColumn Width="195">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Редагувати"
                                        Command="{Binding DataContext.StartEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#F39C12" Foreground="White" BorderThickness="0" Margin="2,0,5,0" Padding="8,5"/>
                                <Button Content="Видалити"
                                        Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#E74C3C" Foreground="White" BorderThickness="0" Margin="0" Padding="8,5"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>