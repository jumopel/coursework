<Window x:Class="coursework.Views.EditMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Керування меню закладу" Height="520" Width="750"
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Назва страви:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="Ціна (грн):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                    <TextBlock Text="Час (хв):" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewPrepTime, UpdateSourceTrigger=PropertyChanged}" Padding="6"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Категорія:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Padding="6"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Дієта:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding DietaryTags}" SelectedItem="{Binding SelectedDietaryTag}" Padding="6"/>
                </StackPanel>

                <Button Grid.Row="1" Grid.Column="2" Content="➕ Додати" Command="{Binding AddProductCommand}" 
                        Height="32" Margin="0,21,0,0" VerticalAlignment="Top"
                        Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding MenuItems}" AutoGenerateColumns="False" 
                  CanUserAddRows="False" Background="White" HeadersVisibility="Column"
                  RowHeight="35" AlternatingRowBackground="#F2F4F4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва Страви" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Ціна" Binding="{Binding Price}" Width="70"/>
                <DataGridTextColumn Header="Приготування" Binding="{Binding PreparationTime.TotalMinutes}" Width="100"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="Тег" Binding="{Binding DietaryTag}" Width="100"/>

                <DataGridTemplateColumn Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="❌ Видалити" 
                                    Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="{Binding}"
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" Margin="5,3"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>