<Window x:Class="coursework.Views.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="GastroMetric - Аналітичний Дашборд" 
        Height="850" Width="1350"
        WindowStartupLocation="CenterOwner" 
        Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Аналітичний Дашборд" FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Ключові показники ефективності (KPI) та інтелектуальні поради" 
                           FontSize="14" Foreground="#7F8C8D" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="💰 План окупності" Command="{Binding OpenFinancialPlanCommand}" 
                        ToolTip="Розрахунок точки беззбитковості"
                        Height="42" Padding="20,0" Margin="0,0,12,0" Cursor="Hand"
                        Background="#2980B9" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0">
                    <Button.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                    </Button.Effect>
                </Button>

                <Button Content="📊 ABC-Аналіз Меню" Command="{Binding OpenAbcAnalysisCommand}" 
                        ToolTip="Класифікація страв за прибутковістю"
                        Height="42" Padding="20,0" Margin="0,0,12,0" Cursor="Hand"
                        Background="#8E44AD" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0">
                    <Button.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                    </Button.Effect>
                </Button>

                <Button Content="📥 Експорт в Excel" Command="{Binding ExportOverallReportCommand}" 
                        ToolTip="Зберегти звіт у файл"
                        Height="42" Padding="20,0" Cursor="Hand"
                        Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0">
                    <Button.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="25,20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ЗАГАЛЬНА ВИРУЧКА" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C0}}" FontSize="36" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="25,20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ЧИСТИЙ ПРИБУТОК" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalNetProfit, StringFormat={}{0:C0}}" FontSize="36" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="10" Padding="25,20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ВІДВІДУВАЧІВ" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalVisitors}" FontSize="36" FontWeight="Bold" Foreground="#2980B9" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Порівняння зон -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Фінанси по зонах (Виручка / Витрати / Прибуток)" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <lvc:CartesianChart Grid.Row="1" Series="{Binding ZoneComparisonChart}" LegendLocation="Bottom">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding ZoneLabels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Сума (грн)" LabelFormatter="{Binding Formatter}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Топ-5 найприбутковіших закладів" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding TopShopsChart}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Заклади" Labels="{Binding TopShopsLabels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Прибуток (грн)" LabelFormatter="{Binding Formatter}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🔔 Бізнес-Асистент" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <Grid Grid.Row="1">

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding BusinessAlerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BackgroundColor}" BorderBrush="{Binding BorderColor}" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <TextBlock Text="{Binding Icon}" Foreground="{Binding BorderColor}" Margin="0,0,8,0" FontSize="18" FontFamily="Segoe UI Emoji"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#555" FontSize="13"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock Text="✅ Усі показники в нормі.&#x0a;Бізнес працює ідеально!" 
                       TextWrapping="Wrap" TextAlignment="Center" 
                       Foreground="#27AE60" FontSize="15" FontWeight="Bold" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BusinessAlerts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" CornerRadius="10" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Прогноз погодинного навантаження" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <lvc:CartesianChart Grid.Row="1" Series="{Binding LoadHeatmapChart}">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding TimeLabels}"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Відвідувачі"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Window>