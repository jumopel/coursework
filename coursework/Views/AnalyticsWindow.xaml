<Window x:Class="coursework.Views.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="GastroMetric - Аналітичний Дашборд" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ЗАГАЛЬНИЙ ПРИБУТОК ФЕСТИВАЛЮ" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C0}}" FontSize="32" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button Grid.Column="1" Content="📥 Експорт в Excel" Command="{Binding ExportOverallReportCommand}" 
                    Width="160" Height="50" VerticalAlignment="Center" Margin="10,0" Cursor="Hand"
                    Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0">
                <Button.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                </Button.Effect>
            </Button>

            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ВІДВІДУВАЧІВ НА ТЕРИТОРІЇ" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TotalVisitors}" FontSize="32" FontWeight="Bold" Foreground="#2980B9" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Частка прибутку по зонах" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <lvc:PieChart Grid.Row="1" Series="{Binding RevenueByZoneChart}" LegendLocation="Bottom" Hoverable="True" DataTooltip="{x:Null}" Loaded="PieChart_Loaded"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Топ-5 найприбутковіших закладів" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <lvc:CartesianChart Grid.Row="1" Series="{Binding TopShopsChart}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Заклади" Labels="{Binding TopShopsLabels}">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Прибуток (грн)" LabelFormatter="{Binding Formatter}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>